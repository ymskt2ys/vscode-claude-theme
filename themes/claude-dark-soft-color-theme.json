{
  "$schema": "vscode://schemas/color-theme",
  "name": "Claude Dark Soft",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "focusBorder": "#D97757",
    "foreground": "#D9D7CD",
    "disabledForeground": "#6B6A65",
    "widget.shadow": "#00000040",
    "selection.background": "#D9775735",
    "descriptionForeground": "#A8A69D",
    "errorForeground": "#C9595F",

    "editor.background": "#262624",
    "editor.foreground": "#D9D7CD",
    "editor.lineHighlightBackground": "#30302E",
    "editor.selectionBackground": "#D9775730",
    "editor.selectionHighlightBackground": "#D9775718",
    "editor.inactiveSelectionBackground": "#D9775718",
    "editor.wordHighlightBackground": "#D9775718",
    "editor.wordHighlightStrongBackground": "#D9775725",
    "editor.findMatchBackground": "#D9775790",
    "editor.findMatchHighlightBackground": "#D9775738",
    "editor.rangeHighlightBackground": "#D9775712",
    "editorCursor.foreground": "#D97757",
    "editorWhitespace.foreground": "#3D3D3A",
    "editorIndentGuide.background1": "#3D3D3A",
    "editorIndentGuide.activeBackground1": "#54534F",
    "editorLineNumber.foreground": "#6B6A65",
    "editorLineNumber.activeForeground": "#C2C0B6",
    "editorRuler.foreground": "#3D3D3A",
    "editorBracketMatch.background": "#D9775725",
    "editorBracketMatch.border": "#D9775750",
    "editorBracketHighlight.foreground1": "#D97757",
    "editorBracketHighlight.foreground2": "#C99764",
    "editorBracketHighlight.foreground3": "#9DAD8F",
    "editorBracketHighlight.foreground4": "#AD9C81",
    "editorBracketHighlight.foreground5": "#BE856F",
    "editorBracketHighlight.foreground6": "#ADBCA5",

    "editorError.foreground": "#C9595F",
    "editorWarning.foreground": "#C99A4D",
    "editorInfo.foreground": "#7A98B5",
    "editorHint.foreground": "#9DAD8F",

    "editorGutter.background": "#262624",
    "editorGutter.modifiedBackground": "#C99764",
    "editorGutter.addedBackground": "#9DAD8F",
    "editorGutter.deletedBackground": "#C9595F",

    "editorGroup.border": "#3D3D3A",
    "editorGroupHeader.tabsBackground": "#1F1E1D",
    "editorGroupHeader.tabsBorder": "#3D3D3A",

    "tab.activeBackground": "#262624",
    "tab.activeForeground": "#F0EEE4",
    "tab.activeBorderTop": "#D97757",
    "tab.inactiveBackground": "#1F1E1D",
    "tab.inactiveForeground": "#908E84",
    "tab.hoverBackground": "#30302E",
    "tab.border": "#3D3D3A",

    "activityBar.background": "#1F1E1D",
    "activityBar.foreground": "#D9D7CD",
    "activityBar.inactiveForeground": "#6B6A65",
    "activityBar.border": "#3D3D3A",
    "activityBar.activeBorder": "#D97757",
    "activityBarBadge.background": "#D97757",
    "activityBarBadge.foreground": "#1F1E1D",

    "sideBar.background": "#1F1E1D",
    "sideBar.foreground": "#B8B6AC",
    "sideBar.border": "#3D3D3A",
    "sideBarTitle.foreground": "#D9D7CD",
    "sideBarSectionHeader.background": "#1F1E1D",
    "sideBarSectionHeader.foreground": "#B8B6AC",
    "sideBarSectionHeader.border": "#3D3D3A",

    "list.activeSelectionBackground": "#D9775728",
    "list.activeSelectionForeground": "#F0EEE4",
    "list.inactiveSelectionBackground": "#D9775718",
    "list.inactiveSelectionForeground": "#D9D7CD",
    "list.hoverBackground": "#30302E",
    "list.hoverForeground": "#F0EEE4",
    "list.focusBackground": "#D9775728",
    "list.highlightForeground": "#D97757",

    "tree.indentGuidesStroke": "#3D3D3A",

    "statusBar.background": "#1F1E1D",
    "statusBar.foreground": "#B8B6AC",
    "statusBar.border": "#3D3D3A",
    "statusBar.debuggingBackground": "#D97757",
    "statusBar.debuggingForeground": "#1F1E1D",
    "statusBarItem.hoverBackground": "#30302E",
    "statusBarItem.remoteBackground": "#D97757",
    "statusBarItem.remoteForeground": "#1F1E1D",

    "titleBar.activeBackground": "#1F1E1D",
    "titleBar.activeForeground": "#D9D7CD",
    "titleBar.inactiveBackground": "#1F1E1D",
    "titleBar.inactiveForeground": "#908E84",
    "titleBar.border": "#3D3D3A",

    "menu.background": "#30302E",
    "menu.foreground": "#D9D7CD",
    "menu.selectionBackground": "#D9775728",
    "menu.selectionForeground": "#F0EEE4",
    "menu.border": "#4A4945",
    "menu.separatorBackground": "#4A4945",

    "input.background": "#30302E",
    "input.foreground": "#D9D7CD",
    "input.border": "#4A4945",
    "input.placeholderForeground": "#6B6A65",
    "inputOption.activeBorder": "#D97757",
    "inputOption.activeBackground": "#D9775735",

    "dropdown.background": "#30302E",
    "dropdown.foreground": "#D9D7CD",
    "dropdown.border": "#4A4945",
    "dropdown.listBackground": "#30302E",

    "button.background": "#D97757",
    "button.foreground": "#1F1E1D",
    "button.hoverBackground": "#E08A6E",
    "button.secondaryBackground": "#4A4945",
    "button.secondaryForeground": "#D9D7CD",

    "badge.background": "#D9775735",
    "badge.foreground": "#F0EEE4",

    "scrollbarSlider.background": "#4A494560",
    "scrollbarSlider.hoverBackground": "#54534F80",
    "scrollbarSlider.activeBackground": "#D9775760",

    "progressBar.background": "#D97757",

    "panel.background": "#262624",
    "panel.border": "#3D3D3A",
    "panelTitle.activeForeground": "#F0EEE4",
    "panelTitle.activeBorder": "#D97757",
    "panelTitle.inactiveForeground": "#908E84",

    "terminal.background": "#262624",
    "terminal.foreground": "#D9D7CD",
    "terminal.selectionBackground": "#D9775730",
    "terminalCursor.background": "#262624",
    "terminalCursor.foreground": "#D97757",
    "terminal.ansiBlack": "#262624",
    "terminal.ansiRed": "#C9595F",
    "terminal.ansiGreen": "#9DAD8F",
    "terminal.ansiYellow": "#C99764",
    "terminal.ansiBlue": "#7A98B5",
    "terminal.ansiMagenta": "#BE856F",
    "terminal.ansiCyan": "#ADBCA5",
    "terminal.ansiWhite": "#D9D7CD",
    "terminal.ansiBrightBlack": "#6B6A65",
    "terminal.ansiBrightRed": "#D26F75",
    "terminal.ansiBrightGreen": "#B2BFA5",
    "terminal.ansiBrightYellow": "#D3A578",
    "terminal.ansiBrightBlue": "#92ADC9",
    "terminal.ansiBrightMagenta": "#CC9883",
    "terminal.ansiBrightWhite": "#F0EEE4",

    "gitDecoration.modifiedResourceForeground": "#C99764",
    "gitDecoration.deletedResourceForeground": "#C9595F",
    "gitDecoration.untrackedResourceForeground": "#9DAD8F",
    "gitDecoration.ignoredResourceForeground": "#6B6A65",
    "gitDecoration.conflictingResourceForeground": "#C99A4D",
    "gitDecoration.addedResourceForeground": "#9DAD8F",

    "diffEditor.insertedTextBackground": "#9DAD8F1A",
    "diffEditor.removedTextBackground": "#C9595F1A",
    "diffEditor.insertedLineBackground": "#9DAD8F12",
    "diffEditor.removedLineBackground": "#C9595F12",

    "notifications.background": "#30302E",
    "notifications.foreground": "#D9D7CD",
    "notifications.border": "#4A4945",
    "notificationCenterHeader.background": "#262624",
    "notificationLink.foreground": "#D97757",

    "editorWidget.background": "#30302E",
    "editorWidget.foreground": "#D9D7CD",
    "editorWidget.border": "#4A4945",
    "editorSuggestWidget.background": "#30302E",
    "editorSuggestWidget.border": "#4A4945",
    "editorSuggestWidget.foreground": "#D9D7CD",
    "editorSuggestWidget.highlightForeground": "#D97757",
    "editorSuggestWidget.selectedBackground": "#D9775728",
    "editorHoverWidget.background": "#30302E",
    "editorHoverWidget.border": "#4A4945",

    "breadcrumb.foreground": "#908E84",
    "breadcrumb.focusForeground": "#D9D7CD",
    "breadcrumb.activeSelectionForeground": "#D97757",
    "breadcrumbPicker.background": "#30302E",

    "textLink.foreground": "#D97757",
    "textLink.activeForeground": "#E08A6E",

    "peekView.border": "#D97757",
    "peekViewEditor.background": "#262624",
    "peekViewResult.background": "#1F1E1D",
    "peekViewTitle.background": "#1F1E1D"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#7A7973",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": {
        "foreground": "#9DAD8F"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#C99764"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language", "support.constant", "constant.character", "constant.other"],
      "settings": {
        "foreground": "#C99764"
      }
    },
    {
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#BE856F"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#BE856F"
      }
    },
    {
      "scope": ["keyword.operator", "punctuation.separator"],
      "settings": {
        "foreground": "#9A988F"
      }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": {
        "foreground": "#D3A578"
      }
    },
    {
      "scope": ["entity.name.class", "entity.name.type", "entity.name.namespace", "support.class", "support.type"],
      "settings": {
        "foreground": "#AD9C81"
      }
    },
    {
      "scope": ["variable", "variable.other", "variable.parameter"],
      "settings": {
        "foreground": "#D9D7CD"
      }
    },
    {
      "scope": ["variable.other.constant", "variable.other.enummember"],
      "settings": {
        "foreground": "#C99764"
      }
    },
    {
      "scope": ["variable.language", "variable.language.this", "variable.language.self"],
      "settings": {
        "foreground": "#BE856F",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#C99764"
      }
    },
    {
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": {
        "foreground": "#BE856F"
      }
    },
    {
      "scope": ["support.type.property-name", "meta.object-literal.key"],
      "settings": {
        "foreground": "#ADBCA5"
      }
    },
    {
      "scope": ["meta.decorator", "punctuation.decorator"],
      "settings": {
        "foreground": "#D97757"
      }
    },
    {
      "scope": ["markup.heading", "entity.name.section"],
      "settings": {
        "foreground": "#D97757",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#C99764",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#BE856F",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.underline.link", "markup.link"],
      "settings": {
        "foreground": "#7A98B5",
        "fontStyle": "underline"
      }
    },
    {
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#9DAD8F",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "#C99764"
      }
    },
    {
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#9DAD8F"
      }
    },
    {
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#C9595F"
      }
    },
    {
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#C99764"
      }
    },
    {
      "scope": ["invalid"],
      "settings": {
        "foreground": "#C9595F"
      }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#C99A4D",
        "fontStyle": "strikethrough"
      }
    },
    {
      "scope": ["punctuation.section.brackets", "punctuation.section.parens", "punctuation.section.braces", "meta.brace"],
      "settings": {
        "foreground": "#B8B6AC"
      }
    },
    {
      "scope": ["keyword.control.import", "keyword.control.from", "keyword.control.export"],
      "settings": {
        "foreground": "#BE856F"
      }
    },
    {
      "scope": ["meta.template.expression", "punctuation.definition.template-expression"],
      "settings": {
        "foreground": "#D97757"
      }
    },
    {
      "scope": ["support.type.property-name.css", "entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": {
        "foreground": "#C99764"
      }
    },
    {
      "scope": ["entity.name.tag.css", "entity.name.tag.scss"],
      "settings": {
        "foreground": "#BE856F"
      }
    },
    {
      "scope": ["support.constant.property-value.css", "constant.other.color"],
      "settings": {
        "foreground": "#ADBCA5"
      }
    }
  ],
  "semanticTokenColors": {
    "parameter": "#B8B6AC",
    "property": "#ADBCA5",
    "variable.readonly": "#C99764",
    "variable.defaultLibrary": "#AD9C81",
    "function.defaultLibrary": "#D3A578",
    "type.defaultLibrary": "#AD9C81",
    "enumMember": "#C99764",
    "namespace": "#AD9C81"
  }
}
