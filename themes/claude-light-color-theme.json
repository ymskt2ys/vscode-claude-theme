    "extensionBadge.remoteForeground": "#FBF8F1",

    "welcomePage.tileBackground": "#F6F2E5",
    "welcomePage.tileHoverBackground": "#ECE7D8",
    "welcomePage.progress.background": "#E0DCCF",
    "walkThrough.embeddedEditorBackground": "#FBF8F1"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment", "string.comment"],
      "settings": {
        "foreground": "#A39A89",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": {
        "foreground": "#6E7E3F"
      }
    },
    {
      "scope": ["string.regexp", "string.regexp.character-class"],
      "settings": {
        "foreground": "#9C6534"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language", "support.constant"],
      "settings": {
        "foreground": "#A87A20"
      }
    },
    {
      "scope": ["constant.character", "constant.other"],
      "settings": {
        "foreground": "#A87A20"
      }
    },
    {
      "scope": ["constant.character.escape", "constant.character.entity"],
      "settings": {
        "foreground": "#B8553A"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#B8553A"
      }
    },
    {
      "scope": ["keyword.operator", "punctuation.separator", "punctuation.terminator"],
      "settings": {
        "foreground": "#6B6557"
      }
    },
    {
      "scope": ["entity.name.function", "support.function", "meta.function-call entity.name.function"],
      "settings": {
        "foreground": "#9C6534"
      }
    },
    {
      "scope": ["entity.name.class", "entity.name.type", "entity.name.namespace", "support.class", "support.type"],
      "settings": {
        "foreground": "#4C6F9B"
      }
    },
    {
      "scope": ["variable", "variable.other", "variable.parameter"],
      "settings": {
        "foreground": "#2B2620"
      }
    },
    {
      "scope": ["variable.other.constant", "variable.other.enummember"],
      "settings": {
        "foreground": "#A87A20"
      }
    },
    {
      "scope": ["variable.language", "variable.language.this", "variable.language.self"],
      "settings": {
        "foreground": "#B8553A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#9C6534"
      }
    },
    {
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": {
        "foreground": "#B8553A"
      }
    },
    {
      "scope": ["support.type.property-name", "meta.object-literal.key", "meta.property.object"],
      "settings": {
        "foreground": "#B8553A"
      }
    },
    {
      "scope": ["variable.other.property", "meta.property.object variable"],
      "settings": {
        "foreground": "#2B2620"
      }
    },
    {
      "scope": ["meta.decorator", "punctuation.decorator", "entity.name.decorator"],
      "settings": {
        "foreground": "#9C6534"
      }
    },
    {
      "scope": ["markup.heading", "markup.heading.setext", "entity.name.section"],
      "settings": {
        "foreground": "#B8553A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#B8553A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#4C6F9B",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.underline.link", "string.other.link", "markup.link"],
      "settings": {
        "foreground": "#9C6534",
        "fontStyle": "underline"
      }
    },
    {
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#A39A89",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code", "markup.raw"],
      "settings": {
        "foreground": "#6E7E3F"
      }
    },
    {
      "scope": ["markup.list.numbered.bullet", "markup.list.unnumbered.bullet", "punctuation.definition.list"],
      "settings": {
        "foreground": "#B8553A"
      }
    },
    {
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#6E7E3F"
      }
    },
    {
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#B33A3F"
      }
    },
    {
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#9C6534"
      }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#B33A3F"
      }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#A87A20",
        "fontStyle": "strikethrough"
      }
    },
    {
      "scope": ["punctuation.definition.string", "punctuation.definition.array", "punctuation.section"],
      "settings": {
        "foreground": "#6B6557"
      }
    },
    {
      "scope": ["meta.brace", "punctuation.section.brackets", "punctuation.section.parens", "punctuation.section.braces"],
      "settings": {
        "foreground": "#3A342C"
      }
    },
    {
      "scope": ["entity.name.label", "punctuation.definition.label"],
      "settings": {
        "foreground": "#C15F3C"
      }
    },
    {
      "scope": [
        "support.type.primitive",
        "support.type.builtin",
        "support.type.object.module"
      ],
      "settings": {
        "foreground": "#4C6F9B"
      }
    },
    {
      "scope": ["meta.import keyword.other", "keyword.control.import", "keyword.control.from", "keyword.control.export"],
      "settings": {
        "foreground": "#B8553A"
      }
    },
    {
      "scope": ["entity.other.inherited-class"],
      "settings": {
        "foreground": "#4C6F9B",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["meta.template.expression", "punctuation.definition.template-expression"],
      "settings": {
        "foreground": "#C15F3C"
      }
    },
    {
      "scope": ["meta.jsx.children", "JSXNested"],
      "settings": {
        "foreground": "#2B2620"
      }
    },
    {
      "scope": ["support.type.property-name.css", "entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": {
        "foreground": "#B8553A"
      }
    },
    {
      "scope": ["entity.name.tag.css", "entity.name.tag.scss"],
      "settings": {
        "foreground": "#B8553A"
      }
    },
    {
      "scope": ["support.constant.property-value.css", "constant.other.color"],
      "settings": {
        "foreground": "#A87A20"
      }
    }
  ],
  "semanticTokenColors": {
    "parameter": "#3A342C",
    "property": "#B8553A",
    "property.readonly": "#B8553A",
    "variable.readonly": "#A87A20",
    "variable.defaultLibrary": "#4C6F9B",
    "function.defaultLibrary": "#9C6534",
    "class.defaultLibrary": "#4C6F9B",
    "type.defaultLibrary": "#4C6F9B",
    "enumMember": "#A87A20",
    "macro": "#B8553A",
    "namespace": "#4C6F9B"
  }
}
