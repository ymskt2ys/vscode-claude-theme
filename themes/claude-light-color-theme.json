    "textLink.foreground": "#C15F3C",
    "textLink.activeForeground": "#A85230",
    "textBlockQuote.background": "#ECE7D8",
    "textBlockQuote.border": "#C15F3C",
    "textCodeBlock.background": "#ECE7D8",
    "textPreformat.foreground": "#9C6534",
    "textSeparator.foreground": "#E0DCCF",

    "minimap.findMatchHighlight": "#C15F3C",
