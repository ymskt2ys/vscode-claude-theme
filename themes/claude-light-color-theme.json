    "gitDecoration.submoduleResourceForeground": "#4C6F9B",
    "gitDecoration.addedResourceForeground": "#6E7E3F",
    "gitDecoration.renamedResourceForeground": "#4C6F9B",
    "gitDecoration.stageModifiedResourceForeground": "#9C6534",
    "gitDecoration.stageDeletedResourceForeground": "#B33A3F",

    "diffEditor.insertedTextBackground": "#6E7E3F20",
    "diffEditor.removedTextBackground": "#B33A3F20",
    "diffEditor.insertedLineBackground": "#6E7E3F15",
