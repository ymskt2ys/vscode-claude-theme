{
  "name": "claude-theme",
  "displayName": "Claude Theme",
  "description": "Warm, eye-friendly VSCode theme inspired by Claude's color palette. Dark, Soft Dark, and Light variants.",
  "version": "0.2.0",
  "publisher": "subtonic",
  "author": {
    "name": "Tetsuyoshi Yamasaki",
    "email": "yamasaki@subtonic.jp"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "claude",
    "anthropic",
    "warm",
    "cream",
    "dark",
    "light",
    "eye-friendly"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Claude Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/claude-dark-color-theme.json"
      },
      {
        "label": "Claude Dark Soft",
        "uiTheme": "vs-dark",
        "path": "./themes/claude-dark-soft-color-theme.json"
      },
      {
        "label": "Claude Light",
        "uiTheme": "vs",
        "path": "./themes/claude-light-color-theme.json"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/subtonic/vscode-claude-theme"
  }
}